# Secrets only. Copy to .env locally; place on droplet at /home/deploy/studysetu/.env. NEVER commit .env.
# Local DATABASE_URL keeps devpass: matches infra/docker-compose.dev.yml's hardcoded dev-only Postgres password.
DATABASE_URL=postgresql+asyncpg://app:devpass@localhost:5432/appdb
JWT_SECRET=CHANGE-openssl-rand-hex-32   # generate: openssl rand -hex 32
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
SENTRY_DSN_API=
SENTRY_DSN_WEB=
POSTGRES_PASSWORD=devpass   # droplet .env: generate: openssl rand -hex 16
# Gmail SMTP (config/email.yaml provider: gmail_smtp). App Password, not account password: myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# External storage keys only when storage.provider != local
# S3_BUCKET= / S3_REGION= / AWS_ACCESS_KEY_ID= / AWS_SECRET_ACCESS_KEY=
# Any config key can be overridden: APP__ai__cache__demo_mode=true
