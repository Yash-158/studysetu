FROM python:3.12-slim
WORKDIR /srv
COPY pyproject.toml ./
RUN pip install --no-cache-dir uv && uv pip install --system -r pyproject.toml
COPY app ./app
COPY ../../config ./config
COPY ../../scripts ./scripts
COPY ../../db ./db
EXPOSE 8000
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
# NOTE: build context is repo root (see infra/docker-compose.yml + CI); paths adjusted at scaffold if needed.
